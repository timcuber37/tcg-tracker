# TCGTracker — environment variable template
# Copy to .env and fill in the values marked with <...>.
# The backend auto-loads this file in local dev (spring.config.import); in Docker
# the same values are passed as container env. Compose also reads SUPABASE_URL /
# SUPABASE_ANON_KEY here to build the frontend.

# ── MySQL (write side) ───────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<your-mysql-root-password>
MYSQL_DB=pokemon_tcg

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=pokemon-tcg-events

# ── Cassandra (read side) ────────────────────────────────────────────────────
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=pokemon_tcg

# ── Supabase (Auth + Postgres) ───────────────────────────────────────────────
SUPABASE_URL=https://<project-id>.supabase.co
# Public "anon" key (Settings → API) — safe to ship to the browser (used by the SPA).
SUPABASE_ANON_KEY=<anon-public-key>
# service_role JWT (Settings → API) — server-side only, never expose to browsers.
SUPABASE_KEY=<service-role-jwt>
# Postgres connection string (Settings → Database → Connection string, Session pooler):
#   postgresql://postgres.[project-id]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres
POSTGRES_DSN=postgresql://postgres.<project-id>:<db-password>@<region>.pooler.supabase.com:5432/postgres

# ── PokéWallet API ───────────────────────────────────────────────────────────
POKEWALLET_API_KEY=<your-pokewallet-api-key>

# ── Google Cloud Vision (card scanning OCR) ──────────────────────────────────
# REST API key (GCP Console → APIs & Services → Credentials). Server-side only.
GOOGLE_VISION_API_KEY=<your-google-vision-api-key>
