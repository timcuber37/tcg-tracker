# PokéCollect — environment variable template
# Copy to .env and fill in the values marked with <...>

# ── MySQL (write side) ───────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<your-mysql-root-password>
MYSQL_DB=pokemon_tcg

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_TOPIC=pokemon-tcg-events

# ── Cassandra (read side) ────────────────────────────────────────────────────
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=pokemon_tcg

# ── Supabase ─────────────────────────────────────────────────────────────────
# URL: https://<project-id>.supabase.co
SUPABASE_URL=https://<project-id>.supabase.co
# Service role key from Settings → API (keep this server-side only, never expose to browsers)
SUPABASE_KEY=<sb_secret_...>

# ── PostgreSQL via Supabase ───────────────────────────────────────────────────
# Connection string from Supabase dashboard: Settings → Database → Connection string (URI)
# Use the "Session mode" pooler URL (port 5432) for compatibility with pgvector:
#   postgresql://postgres.[project-id]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Or the direct connection:
#   postgresql://postgres:[db-password]@db.[project-id].supabase.co:5432/postgres
POSTGRES_DSN=postgresql://postgres:<db-password>@db.<project-id>.supabase.co:5432/postgres

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ── PokéWallet API ───────────────────────────────────────────────────────────
POKEWALLET_API_KEY=<your-pokewallet-api-key>

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=<random-secret-at-least-32-chars>
FLASK_DEBUG=true
